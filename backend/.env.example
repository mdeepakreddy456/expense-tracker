# Copy this file to .env and fill in values for local development

# Port the API listens on (default: 3001)
PORT=3001

# Directory where the SQLite database file is stored
# In production (Render) this is /var/data
DATA_DIR=./data

# Allowed CORS origin — set to your frontend URL in production
# Example: https://fenmo-frontend.onrender.com
ALLOWED_ORIGIN=*

# Node environment
NODE_ENV=development
